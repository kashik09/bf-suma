<script id="jquery-js-after">
jQuery(document).ready(function($) {
            'use strict';
            
            const modal = $('#benayes-quickview-modal');
            const modalContent = $('#benayes-quickview-content');
            
            // Quick view button click
            $(document).on('click', '.benayes-quickview-btn', function(e) {
                e.preventDefault();
                e.stopPropagation();
                
                const productId = $(this).data('product-id');
                
                if (!productId) {
                    modalContent.html('<div style="text-align:center;padding:40px;color:red;">Error: No product ID found</div>');
                    modal.show();
                    return;
                }
                
                // Show loading
                modalContent.html('<div style="text-align:center;padding:60px;font-size:16px;">Loading product details...</div>');
                modal.show();
                $('body').css('overflow', 'hidden');
                
                // AJAX call
                $.ajax({
                    url: 'https://bfsumastore.com/wp-admin/admin-ajax.php',
                    type: 'POST',
                    data: {
                        action: 'benayes_quickview',
                        product_id: productId
                    },
                    success: function(response) {
                        if (response && response.success) {
                            modalContent.html(response.data);
                        } else {
                            let errorMsg = 'Unknown error occurred';
                            if (response && response.data) {
                                errorMsg = response.data;
                            }
                            modalContent.html('<div style="text-align:center;padding:40px;color:red;">Error: ' + errorMsg + '</div>');
                        }
                    },
                    error: function(xhr, status, error) {
                        modalContent.html('<div style="text-align:center;padding:40px;color:red;">AJAX Error: ' + error + '</div>');
                    }
                });
            });
            
            // Close modal when clicking close button
            $(document).on('click', '.benayes-modal-close', function(e) {
                e.preventDefault();
                e.stopPropagation();
                modal.hide();
                $('body').css('overflow', '');
            });
            
            // Close modal when clicking outside content
            $(document).on('click', '.benayes-modal', function(e) {
                if (e.target === this) {
                    modal.hide();
                    $('body').css('overflow', '');
                }
            });
            
            // Prevent modal content click from closing
            $(document).on('click', '.benayes-modal-content', function(e) {
                e.stopPropagation();
            });
            
            // Escape key to close
            $(document).on('keyup', function(e) {
                if (e.keyCode === 27) {
                    modal.hide();
                    $('body').css('overflow', '');
                }
            });
            
            // Quantity controls
            $(document).on('click', '.benayes-quantity-btn', function() {
                const input = $(this).siblings('.benayes-quantity-input');
                let currentVal = parseInt(input.val()) || 1;
                const max = parseInt(input.attr('max')) || 999;
                
                if ($(this).hasClass('benayes-quantity-minus')) {
                    if (currentVal > 1) {
                        input.val(currentVal - 1);
                    }
                } else {
                    if (currentVal < max) {
                        input.val(currentVal + 1);
                    }
                }
            });
            
            // Add to cart button - using WooCommerce AJAX
            $(document).on('click', '.benayes-quickview-addcart', function(e) {
                e.preventDefault();
                const productId = $(this).data('product-id');
                const quantity = $('#benayes-quantity').val() || 1;
                
                if (!productId) {
                    alert('Error: Product ID not found');
                    return;
                }
                
                // Show loading state
                const button = $(this);
                const originalText = button.text();
                button.text('ADDING...').prop('disabled', true);
                
                // Use WooCommerce AJAX add to cart
                $.ajax({
                    type: 'POST',
                    url: wc_add_to_cart_params.ajax_url,
                    data: {
                        action: 'woocommerce_add_to_cart',
                        product_id: productId,
                        quantity: quantity
                    },
                    success: function(response) {
                        if (response && response.error && response.product_url) {
                            // If there's an error, redirect to product page
                            window.location.href = response.product_url;
                        } else if (response && response.error) {
                            // Show error message
                            alert('Error: ' + response.error);
                            button.text(originalText).prop('disabled', false);
                        } else {
                            // Success - update cart and show message
                            $(document.body).trigger('wc_fragment_refresh');
                            alert('Product added to cart successfully!');
                            modal.hide();
                            $('body').css('overflow', '');
                        }
                    },
                    error: function() {
                        // Fallback to direct URL method
                        window.location.href = '?add-to-cart=' + productId + '&quantity=' + quantity;
                    },
                    complete: function() {
                        button.text(originalText).prop('disabled', false);
                    }
                });
            });
            
            // Buy now button - add to cart and redirect to checkout
            $(document).on('click', '.benayes-quickview-buynow', function(e) {
                e.preventDefault();
                const productId = $(this).data('product-id');
                const quantity = $('#benayes-quantity').val() || 1;
                
                if (!productId) {
                    alert('Error: Product ID not found');
                    return;
                }
                
                // Show loading state
                const button = $(this);
                const originalText = button.text();
                button.text('PROCESSING...').prop('disabled', true);
                
                // Use WooCommerce AJAX add to cart then redirect to checkout
                $.ajax({
                    type: 'POST',
                    url: wc_add_to_cart_params.ajax_url,
                    data: {
                        action: 'woocommerce_add_to_cart',
                        product_id: productId,
                        quantity: quantity
                    },
                    success: function(response) {
                        if (response && response.error && response.product_url) {
                            // If there's an error, redirect to product page
                            window.location.href = response.product_url;
                        } else if (response && response.error) {
                            // Show error message
                            alert('Error: ' + response.error);
                            button.text(originalText).prop('disabled', false);
                        } else {
                            // Success - redirect to checkout
                            window.location.href = 'https://bfsumastore.com/checkout/';
                        }
                    },
                    error: function() {
                        // Fallback to direct URL method
                        window.location.href = '?add-to-cart=' + productId + '&quantity=' + quantity + '&redirect_to_checkout=1';
                    }
                });
            });
        });
        
//# sourceURL=jquery-js-after
</script>
