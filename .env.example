# ==========================================================
# BF Suma - Core app configuration
# ==========================================================
#
# IMPORTANT: Phone numbers are NOT env vars.
# They live in src/config/contact.ts
#

# Public Supabase project URL (used by browser and server).
NEXT_PUBLIC_SUPABASE_URL=

# Public Supabase anonymous key (safe for browser usage).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site URL used for canonical metadata, sitemap, and robots (example: https://bfsuma.com).
NEXT_PUBLIC_SITE_URL=

# Google Search Console verification token value from the provided meta tag content.
# Example: if Google gives <meta name="google-site-verification" content="abc123" />, set this to abc123.
NEXT_PUBLIC_GSC_VERIFICATION_TOKEN=

# Google Analytics 4 Measurement ID (starts with G-) used for storefront traffic and conversion tracking.
# Leave blank to disable analytics script loading.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# Private Supabase service role key (server only, never expose publicly).
SUPABASE_SERVICE_ROLE_KEY=

# Admin session signing secret (required, 32+ chars).
# Generate with: openssl rand -base64 32
ADMIN_SESSION_SECRET=

# Secret used by protected on-demand revalidation endpoints.
# Generate with: openssl rand -hex 32
REVALIDATE_SECRET=


# ==========================================================
# Email / newsletter delivery (optional but recommended)
# ==========================================================

# Set to "false" to disable welcome/newsletter email sending.
NEWSLETTER_WELCOME_EMAIL_ENABLED=true

# Set to "false" to disable all transactional/lifecycle email sends.
EMAIL_DELIVERY_ENABLED=true

# Master switch for lifecycle automation (abandoned cart, review requests, re-engagement).
# Default false for safety: set to "true" only after functions/cron are deployed and tested.
LIFECYCLE_EMAILS_ENABLED=false

# Resend API key for transactional email delivery.
RESEND_API_KEY=

# Verified sender email in Resend (example: no-reply@yourdomain.com).
RESEND_FROM_EMAIL=

# Optional reply-to email for customer responses.
RESEND_REPLY_TO_EMAIL=


# ==========================================================
# Cloudflare Turnstile CAPTCHA (anti-spam for contact/newsletter forms)
# ==========================================================

# Public site key from Cloudflare Turnstile dashboard (exposed to browser).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Secret key from Cloudflare Turnstile dashboard (server-side verification only, never expose).
TURNSTILE_SECRET_KEY=


# ==========================================================
# Feature flags
# ==========================================================

# Enable old scaffold admin routes (usually keep false).
ALLOW_ADMIN_SCAFFOLD_ROUTES=false

# Enable old scaffold API routes (usually keep false).
ALLOW_SCAFFOLD_API_ROUTES=false

# Enable FAQ page route.
ALLOW_FAQ_PAGE=false

# Enable PDF debug tracing in browser console.
NEXT_PUBLIC_SHOW_PDF_TRACE=false


# ==========================================================
# Local scripts / preflight helpers
# ==========================================================

# Base URL used by scripts/preflight-check.js.
BASE_URL=http://127.0.0.1:3000


# ==========================================================
# Production admin bootstrap (one-time first admin creation)
# ==========================================================
# Usage:
#   BOOTSTRAP_ADMIN_EMAIL=admin@yourcompany.com \
#   BOOTSTRAP_ADMIN_PASSWORD='YourSecureP@ssw0rd123!' \
#   BOOTSTRAP_ADMIN_NAME='Admin User' \
#   BOOTSTRAP_ADMIN_ROLE=SUPER_ADMIN \
#   npx ts-node scripts/bootstrap-admin.ts

BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=
BOOTSTRAP_ADMIN_ROLE=SUPER_ADMIN
